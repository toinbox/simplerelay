# ============================================
# SimpleRelay Configuration
# Copy to .env: cp env.example .env
# ============================================

# --- Admin account (created on first start) ---
RELAY_ADMIN_EMAIL=admin@example.com
RELAY_ADMIN_PASSWORD=strongpassword

# --- Security ---
# Generate: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
RELAY_SECRET_KEY=change-me-in-production

# --- Database ---
POSTGRES_USER=simplerelay
POSTGRES_PASSWORD=simplerelay
POSTGRES_DB=simplerelay
RELAY_DATABASE_URL=postgresql://simplerelay:simplerelay@db:5432/simplerelay


# --- System SMTP (for verification & reset emails) ---
# If empty, emails are logged to console (dev mode)
RELAY_SMTP_HOST=mx.example.com
RELAY_SMTP_PORT=587
RELAY_SMTP_USER=noreply@mx.example.com
RELAY_SMTP_PASSWORD=
RELAY_SMTP_FROM=noreply@mx.example.co
RELAY_SMTP_TLS=true

# --- Base URL (for email links) ---
RELAY_BASE_URL=https://relay.example.com:8080

# --- Relay SMTP hostname (what users connect to) ---
RELAY_HOSTNAME=relay.example.com
RELAY_PORT=2525

RELAY_PUBLIC_IP= 203.0.113.10
